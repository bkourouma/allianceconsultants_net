# Base URL du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://allianceconsultants.net

# Base de données PostgreSQL (Lead uniquement)
DATABASE_URL=postgresql://allcc:allcc@localhost:5432/allcc?schema=public

# Authentification admin HTTP Basic Auth (/admin/leads)
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Matomo (optionnel — laisser vide pour désactiver le tracking)
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# SMTP — notifications email des leads
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=
SMTP_FROM="Alliance Consultants <noreply@allianceconsultants.net>"
LEAD_NOTIFY_TO=commercial@allianceconsultants.net
