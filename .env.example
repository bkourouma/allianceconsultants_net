# Base URL du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://allianceconsultants.net

# Base de données PostgreSQL (Lead uniquement)
DATABASE_URL=postgresql://allcc:allcc@localhost:5432/allcc?schema=public

# NextAuth (Auth.js v5) — backoffice /admin
# Générer avec : `openssl rand -base64 32`
AUTH_SECRET=replace-me-with-32-random-bytes-base64
AUTH_TRUST_HOST=true

# Seed de l'utilisateur admin unique (lu uniquement par prisma/seed.ts).
# Mot de passe ≥ 12 caractères (au moins 1 minuscule, 1 majuscule, 1 chiffre).
ADMIN_EMAIL=admin@allianceconsultants.net
ADMIN_PASSWORD=ChangeMeStrongPassword123
ADMIN_NAME=Admin Alliance

# Anti-bruteforce du formulaire de connexion (POST /api/auth/...) — défaut 5 / 10 min / IP
LOGIN_RATE_LIMIT_PER_10MIN=5

# Matomo (optionnel — laisser vide pour désactiver le tracking)
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# Vérification moteurs de recherche (balises meta — optionnel)
# Google Search Console : valeur du content="..." de la meta tag fournie par GSC.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools : valeur du content="..." de la meta msvalidate.01.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# SMTP — notifications email des leads
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=
SMTP_FROM="Alliance Consultants <noreply@allianceconsultants.net>"
LEAD_NOTIFY_TO=commercial@allianceconsultants.net

# Anti-flood lead form (POST /api/lead) — défaut 5 / 10 min / IP
LEAD_RATE_LIMIT_PER_10MIN=5
