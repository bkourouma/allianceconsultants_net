# Place this file on the VPS at /home/deployer/apps/allianceconsultants-net/.env.production
# (do NOT commit the real one)

NEXT_PUBLIC_SITE_URL=https://allianceconsultants.net

# Postgres (consumed by both the db service and the web service via DATABASE_URL)
POSTGRES_USER=allcc
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=allcc
DATABASE_URL=postgresql://allcc:change-me-strong@db:5432/allcc?schema=public

# NextAuth
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Admin seed (only used by prisma seed)
ADMIN_EMAIL=admin@allianceconsultants.net
ADMIN_PASSWORD=ChangeMeStrongPassword123
ADMIN_NAME=Admin Alliance

LOGIN_RATE_LIMIT_PER_10MIN=5
LEAD_RATE_LIMIT_PER_10MIN=5

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=
SMTP_FROM="Alliance Consultants <noreply@allianceconsultants.net>"
LEAD_NOTIFY_TO=commercial@allianceconsultants.net

# Matomo (optional)
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=

# Search engine verifications (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
