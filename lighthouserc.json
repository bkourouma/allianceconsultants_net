{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/solutions",
        "http://localhost:3000/solutions/docupro-suite",
        "http://localhost:3000/solutions/medicpro",
        "http://localhost:3000/solutions/cliniquepro",
        "http://localhost:3000/solutions/immotopia-cloud",
        "http://localhost:3000/solutions/annonces-web",
        "http://localhost:3000/solutions/ecole-digitale"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "emulatedFormFactor": "mobile"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "categories:seo": ["warn", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
