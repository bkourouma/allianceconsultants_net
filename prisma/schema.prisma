generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Lead (feature 001 — homepage / pages solutions corporate). Inchangé.
// ===========================================================================

enum LeadIntent {
  DEMO
  CONTACT
  TRAINING
  AUTOMATION
  DIAGNOSTIC
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  ARCHIVED
  SPAM
}

model Lead {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())

  // Intention & origine (transmis par les query params des CTA)
  intent       LeadIntent
  solutionSlug String?
  fromPage     String?
  fromBlock    String?

  // Champs formulaire (feature /contact-demo)
  name         String
  email        String
  phone        String
  organization String
  message      String     @db.Text
  consent      Boolean

  // Métadonnées anti-spam (RGPD)
  userAgent    String?    @db.Text
  ipHash       String?
  honeypot     String?

  // Cycle de vie
  status       LeadStatus @default(NEW)
  notes        String?    @db.Text
  contactedAt  DateTime?
  contactedBy  String?

  @@index([createdAt])
  @@index([status])
  @@index([intent])
}

// ===========================================================================
// Backoffice + Blog (feature 002).
// ===========================================================================

enum Role {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         Role       @default(ADMIN)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  posts        BlogPost[]

  @@index([email])
}

model BlogPost {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  excerpt        String         @db.Text
  coverUrl       String?
  coverAlt       String?
  bodyHtml       String         @db.Text
  seoTitle       String?
  seoDescription String?
  ogImage        String?
  status         PostStatus     @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  authorId       String
  author         User           @relation(fields: [authorId], references: [id], onDelete: Restrict)

  tags           BlogPostTag[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([authorId])
}

model BlogTag {
  id        String        @id @default(cuid())
  slug      String        @unique
  label     String
  createdAt DateTime      @default(now())

  posts     BlogPostTag[]
}

model BlogPostTag {
  postId String
  tagId  String

  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// ===========================================================================
// Module « Références » (cas clients / projets) — persisté en base.
// Gérable depuis le backoffice (/admin/references). Distinct du type
// `Reference` (logos / témoignages) historiquement chargé via MDX dans
// `content/references/*` et utilisé par la section homepage.
// ===========================================================================

model ProjectReference {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Champs métier (correspondent aux libellés du backoffice)
  companyName  String   // Nom de la société
  projectTitle String   // Titre du projet
  year         String   // Année — texte libre (ex. "2015", "2015 (démarrage octobre 2015 ; achèvement janvier 2016)")
  duration     String   // Durée — texte libre (ex. "6 mois", "1 mois (prévu)", "T1 2024 → T3 2025")
  problem      String   @db.Text // Problématique
  solution     String   @db.Text // Solution proposée
  impact       String?  @db.Text // Impact / résultat — optionnel (peut être renseigné a posteriori)

  // Champs additionnels
  sector       String?  // Secteur d'activité (ex. "Santé", "Immobilier")
  logoUrl      String?  // Logo client (URL absolue ou relative à /public)
  published    Boolean  @default(true)
  displayOrder Int      @default(0)

  @@index([published, displayOrder])
}
